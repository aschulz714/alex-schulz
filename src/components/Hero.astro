---
import { heroPlaces as places } from '../data/profile';
---

<section class="relative overflow-hidden">
  <div class="section-shell pt-10 pb-14 md:pt-16 md:pb-20">
    <div class="dossier-panel rounded-lg">
      <div class="grid grid-cols-1 md:grid-cols-[1.1fr_0.9fr]">
        <div class="border-b border-hairline p-5 md:border-b-0 md:border-r md:p-8 lg:p-10">
          <div class="mb-8 flex flex-wrap items-center gap-3">
            <p class="coord text-accent">Alex Schulz / 2026</p>
            <span class="coord rounded-sm border border-signal/30 bg-signal-soft px-2 py-1 text-signal">
              CPA + GEOINT
            </span>
          </div>

          <h1 class="section-heading max-w-3xl text-5xl leading-[0.96] text-balance sm:text-6xl md:text-7xl">
            Alex Schulz maps the financial signals hiding in the physical world.
          </h1>

          <div class="annotation mt-8">
            <p class="min-h-[1.35em] text-2xl font-semibold leading-snug text-ink md:text-3xl">
              <span id="role-cycler" class="inline-block">CPA.</span>
            </p>
            <p class="section-copy mt-4 max-w-xl text-base md:text-lg">
              A living resume and portfolio for work at the intersection of accounting discipline,
              geospatial intelligence, and market data that still has a latitude and longitude.
            </p>
          </div>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="#work" class="button-primary">View work <span class="mono text-xs" aria-hidden="true">↓</span></a>
            <a href="/resume.pdf" class="button-secondary">Resume <span class="mono text-xs" aria-hidden="true">↓</span></a>
            <a href="mailto:alex.j.schulz@gmail.com" class="button-secondary">Contact</a>
          </div>

          <dl class="ledger-rule mt-9 grid grid-cols-1 divide-y divide-hairline sm:grid-cols-3 sm:divide-x sm:divide-y-0">
            <div class="p-4 sm:pl-0">
              <dt class="coord text-accent">Credential</dt>
              <dd class="mt-2 text-lg font-semibold text-ink">CPA + MS GEOINT</dd>
            </div>
            <div class="p-4">
              <dt class="coord text-signal">Estimated overlap</dt>
              <dd class="mt-2 text-lg font-semibold text-ink">10-20 in the US</dd>
            </div>
            <div class="p-4 sm:pr-0">
              <dt class="coord">Current thesis</dt>
              <dd class="mt-2 text-lg font-semibold text-ink">Spatial finance</dd>
            </div>
          </dl>
        </div>

        <div class="flex min-h-[34rem] flex-col p-3 md:min-h-0 md:p-4">
          <div class="mb-3 flex items-center justify-between gap-3 px-1">
            <p class="coord text-accent">Places that shaped the lens</p>
            <p class="coord">Personal atlas</p>
          </div>
          <div class="relative min-h-[24rem] flex-1 md:min-h-0">
            <div
              id="hero-map"
              class="relative h-full min-h-[24rem] overflow-hidden rounded-md border border-hairline bg-accent-soft md:min-h-0"
            ></div>

            <div class="absolute left-3 top-3 max-w-[calc(100%-1.5rem)] rounded-sm border border-hairline bg-paper-soft/92 px-3 py-2 backdrop-blur">
              <p id="place-label" class="coord text-accent">{places[0].label}</p>
              <p id="place-note" class="mt-1 text-xs leading-snug text-ink-soft">{places[0].note}</p>
            </div>

            <p id="place-coord" class="coord mono absolute bottom-3 right-3 rounded-sm border border-hairline bg-paper-soft/90 px-2 py-1 backdrop-blur">
              {places[0].coords[1].toFixed(3)}, {places[0].coords[0].toFixed(3)}
            </p>
          </div>

          <div class="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-3">
            {places.map((place, index) => (
              <button
                type="button"
                class={`place-button ${index === 0 ? 'is-active' : ''}`}
                data-place-index={index}
              >
                <span class="mono text-[0.65rem]">{String(index + 1).padStart(2, '0')}</span>
                <span>{place.label}</span>
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <script type="application/json" id="hero-places-data" set:html={JSON.stringify(places)}></script>
</section>

<script>
  type Place = {
    label: string;
    note: string;
    coords: [number, number];
    zoom: number;
  };

  const placesData = document.getElementById('hero-places-data');
  const places = JSON.parse(placesData?.textContent ?? '[]') as Place[];
  const HOME = places[0]?.coords ?? [-122.2021, 47.979];
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const mapContainer = document.getElementById('hero-map');
  const labelEl = document.getElementById('place-label');
  const noteEl = document.getElementById('place-note');
  const coordEl = document.getElementById('place-coord');
  const placeButtons = document.querySelectorAll<HTMLButtonElement>('.place-button[data-place-index]');

  if (mapContainer && places.length) {
    const markerEls: HTMLElement[] = [];
    let map: import('maplibre-gl').Map | null = null;

    function setPlace(index: number, fly = true) {
      const place = places[index];
      if (!place) return;

      placeButtons.forEach((button, i) => button.classList.toggle('is-active', i === index));
      markerEls.forEach((marker, i) => marker.classList.toggle('is-active', i === index));
      if (labelEl) labelEl.textContent = place.label;
      if (noteEl) noteEl.textContent = place.note;
      if (coordEl) coordEl.textContent = `${place.coords[1].toFixed(3)}, ${place.coords[0].toFixed(3)}`;

      if (fly && map) {
        map.flyTo({
          center: place.coords,
          zoom: place.zoom,
          duration: prefersReducedMotion ? 0 : 1100,
          essential: true,
        });
      }
    }

    async function initMap() {
      await import('maplibre-gl/dist/maplibre-gl.css');
      const { default: maplibregl } = await import('maplibre-gl');

      map = new maplibregl.Map({
        container: mapContainer,
        style: 'https://tiles.openfreemap.org/styles/positron',
        center: HOME,
        zoom: places[0]!.zoom,
        interactive: false,
        attributionControl: { compact: true },
        pitchWithRotate: false,
        dragRotate: false,
      });

      map.on('load', () => {
      mapContainer.classList.add('map-ready');

      const style = map!.getStyle();
      (style.layers ?? []).forEach((layer) => {
        if (layer.type === 'symbol') {
          map!.setLayoutProperty(layer.id, 'visibility', 'none');
        }
      });

      places.forEach((place, index) => {
        const marker = document.createElement('button');
        marker.type = 'button';
        marker.className = `hero-map-marker ${index === 0 ? 'is-active' : ''}`;
        marker.textContent = String(index + 1).padStart(2, '0');
        marker.setAttribute('aria-label', place.label);
        marker.addEventListener('click', () => setPlace(index));
        markerEls.push(marker);
        new maplibregl.Marker({ element: marker, anchor: 'center' }).setLngLat(place.coords).addTo(map!);
      });
    });
    }

    if ('IntersectionObserver' in window) {
      const mapObserver = new IntersectionObserver(
        (entries) => {
          if (entries.some((entry) => entry.isIntersecting)) {
            mapObserver.disconnect();
            initMap();
          }
        },
        { rootMargin: '220px 0px' }
      );
      mapObserver.observe(mapContainer);
    } else {
      initMap();
    }

    placeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        setPlace(Number(button.dataset.placeIndex ?? 0));
      });
    });
  }

  // Role cycler — quiet and slow. Each entry is a complete noun phrase so grammar holds.
  const roles = ['CPA.', 'Geospatial analyst.', 'Developer.', 'All three.'];
  const cycler = document.getElementById('role-cycler');
  if (cycler && !prefersReducedMotion) {
    let i = 0;
    cycler.style.transition = 'opacity 400ms ease';
    setInterval(() => {
      cycler.style.opacity = '0';
      setTimeout(() => {
        i = (i + 1) % roles.length;
        cycler.textContent = roles[i]!;
        cycler.style.opacity = '1';
      }, 400);
    }, 2800);
  }
</script>
