---
import { milestones } from '../data/timeline';

const chapterFor = (index: number) => {
  if (index === 0) return 'Accounting foundation';
  if (index <= 2) return 'Family office + production';
  if (index <= 5) return 'Geospatial pivot';
  return 'Spatial finance thesis';
};
---

<section id="timeline" class="relative border-y border-hairline bg-paper-soft/45 py-14 md:py-24">
  <div class="section-shell">
    <div class="mb-10 grid grid-cols-1 gap-7 md:mb-14 md:grid-cols-[180px_1fr] md:gap-14">
      <p class="coord pt-1">01 / Journey</p>
      <div>
        <h2 class="section-heading max-w-2xl text-3xl md:text-5xl">
          A career ledger, not a straight line.
        </h2>
        <p class="section-copy mt-5 max-w-xl text-base md:text-lg">
          Each chapter became the foundation for the next: accounting discipline, production pace,
          geospatial craft, and product judgment layered into one working profile, often built remotely
          from Washington.
        </p>
      </div>
    </div>

    <ol class="timeline-list border-t border-hairline">
      {milestones.map((m, index) => (
        <li
          class="milestone reveal group grid grid-cols-[3.5rem_1fr] gap-x-5 gap-y-3 border-b border-hairline py-6 transition-colors hover:bg-paper-soft/55 md:grid-cols-[5rem_1fr_auto] md:gap-x-8 md:py-7"
        >
          <div class="pt-1">
            <span class="timeline-number">{String(index + 1).padStart(2, '0')}</span>
            <span class="coord mt-3 block text-accent">{m.year}</span>
          </div>
          <div class="relative pl-5 md:pr-4">
            <span class="timeline-dot" aria-hidden="true"></span>
            <p class="coord mb-3 text-signal">{chapterFor(index)}</p>
            <h3 class="font-sans text-xl font-semibold leading-snug md:text-2xl">
              {m.title}
            </h3>
            <p class="section-copy mt-2 max-w-2xl text-sm md:text-base">
              {m.blurb}
            </p>
          </div>
          <p class="coord col-start-2 text-ink-muted md:col-start-3 md:text-right md:self-start">
            {m.where}
          </p>
        </li>
      ))}
    </ol>
  </div>
</section>

<script>
  const revealables = document.querySelectorAll<HTMLElement>('.reveal');
  if (revealables.length && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { rootMargin: '-10% 0px -10% 0px', threshold: 0 }
    );
    revealables.forEach((el) => observer.observe(el));
  } else {
    revealables.forEach((el) => el.classList.add('is-visible'));
  }
</script>
