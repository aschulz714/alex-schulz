---
import { notes } from '../data/profile';
---

<section id="also" class="relative border-y border-hairline bg-paper-soft/45 py-14 md:py-24">
  <div class="section-shell">
    <div class="mb-10 grid grid-cols-1 gap-7 md:mb-14 md:grid-cols-[180px_1fr] md:gap-14">
      <p class="coord pt-1">03 / Notes</p>
      <div>
        <h2 class="section-heading max-w-2xl text-3xl md:text-5xl">
          Things the resume hides.
        </h2>
        <p class="section-copy mt-5 max-w-xl text-base md:text-lg">
          Six footnotes with the texture a single bio line never quite captures.
        </p>
      </div>
    </div>

    <ol class="notes-list grid grid-cols-1 border-t border-hairline md:grid-cols-2 lg:grid-cols-3">
      {notes.map((n, i) => (
        <li class="reveal border-b border-hairline bg-paper-soft/35 p-5 md:border-r md:p-6 lg:[&:nth-child(3n)]:border-r-0">
          <span class="coord text-accent">
            {String(i + 1).padStart(2, '0')}
          </span>
          <h3 class="mt-8 font-sans text-lg font-semibold leading-snug md:text-xl">
            {n.lead}
          </h3>
          <p class="section-copy mt-3 text-sm md:text-base">
            {n.body}
          </p>
        </li>
      ))}
    </ol>
  </div>
</section>
