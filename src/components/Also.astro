<section id="also" class="relative border-y border-hairline bg-paper-soft/45 py-16 md:py-28">
  <div class="section-shell">
    <div class="mb-12 grid grid-cols-1 gap-7 md:mb-16 md:grid-cols-[180px_1fr] md:gap-14">
      <p class="coord pt-1">03 / Notes</p>
      <div>
        <h2 class="section-heading max-w-2xl text-3xl md:text-5xl">
          Things the resume hides.
        </h2>
